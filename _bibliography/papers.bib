@article{pourghasem2025scoping,
  abbr={Disabil. Rehabil.},
  title={The use of digital avatars to improve virtual rehabilitation health outcomes amongst adults with health conditions: a scoping review},
  author={Pourghasem, Fateme and Colella, Theresa J. F. and Gopaul, Ushini and Anderson, Marilyn and Ashraf, Ayesha and Khan, Sujoy},
  journal={Disability and Rehabilitation},
  pages={1--22},
  year={2025},
  publisher={Taylor \& Francis},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:UeHWp8X0CEIC},
  selected={true},
  abstract={This scoping review examines how digital avatars are used in adult virtual rehabilitation and what health outcomes have been reported. Across 45 studies (from 3,877 screened), avatars were most commonly used in stroke and amputee rehabilitation and were typically humanoid, providing real-time feedback on screens or mobile devices; many studies reported improvements in function, adherence, or engagement. The review highlights gaps in advanced AI-driven personalization, privacy/ethics, co-design, standardized outcome measures, and long-term evaluation.}
}

@article{gopaul2024adaptive,
  abbr={Arch. PM\&R},
  title={Development of an adaptive virtual assistant to support virtual rehabilitation of the upper limb after stroke: A co-design approach},
  author={Gopaul, Ushini and Khan, Sujoy and Abedi, Ali and Pourghasem, Fateme and Bayley, Mark and Colella, Theresa J. F.},
  journal={Archives of Physical Medicine and Rehabilitation},
  volume={105},
  number={4},
  pages={e58--e59},
  year={2024},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:9yKSN-GCB0IC},
  abstract={This work describes the development of an adaptive virtual assistant to support upper-limb virtual rehabilitation after stroke using a co-design approach with clinical and end-user input. It focuses on aligning assistant behavior, guidance, and feedback with real rehabilitation workflows to improve usability and engagement in remote therapy. (A full abstract was not publicly available via PubMed/publisher indexing at the time of writing; this summary is based on the citation and title.)}
}

@misc{abedi2024ava,
  abbr={AI Rehab},
  title={{AVA}: {AI}-driven Virtual Rehabilitation Assistant},
  author={Abedi, Ali and Colella, Theresa J. F. and Bayley, Mark and Gopaul, Ushini and Mahajan, Aarohi and Reddy, Tejas and others},
  year={2024},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:d1gkVwhDpl0C},
  selected={true},
  note={AI-driven assistant for virtual rehabilitation; engineering and evaluation contributions.},
  abstract={AVA is an AI-driven virtual rehabilitation assistant designed to guide users through exercises remotely, combining interactive avatar-based guidance with computer-vision-based movement tracking. The project targets scalable, home-based rehabilitation workflows where real-time feedback, usability, and measurement quality are critical.}
}

@mastersthesis{pourghasem2025thesis,
  abbr={MASc},
  title={Feasibility Pilot Testing of an {AI}-based Virtual Assistant among Healthy Adults to Support Virtual Rehabilitation},
  author={Pourghasem, Fateme},
  school={University of Toronto},
  year={2025},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:qjMakFHDy7sC},
  selected={true},
  abstract={This thesis assesses the feasibility of an AI-based virtual assistant (AVA) for virtual rehabilitation using cloud-based computer vision from laptop/smartphone RGB cameras to track joint movement and guide users via an interactive avatar. A scoping review on digital avatars informed the system design, followed by pilot evaluation in healthy adults aged 25--74 for engagement, usability, and technical performance. Results indicated high usability and positive experiences, alongside practical improvement areas (e.g., attention focus, camera setup) and movement-detection limitations (notably for leg raises) inherent to RGB-only tracking.}
}

@article{azangou2022gbd,
  abbr={Arch. Osteoporos},
  title={Attributable disease burden related to low bone mineral density in {Iran} from 1990 to 2019: results from the {Global Burden of Disease} 2019},
  author={Azangou-Khyavy, M. and Saeedi Moghaddam, S. and Mohammadi, E. and Shobeiri, P. and others},
  journal={Archives of Osteoporosis},
  volume={17},
  number={1},
  pages={140},
  year={2022},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:u5HHmVD_uO8C},
  abstract={Using Global Burden of Disease 2019 estimates, this study quantifies the burden attributable to low bone mineral density (low bone mass/osteoporosis) in Iran from 1990--2019 at national and subnational levels. While age-standardized DALYs and deaths decreased over time, the absolute attributable counts increased; burden was generally higher in males (except Tehran), and motor vehicle injuries and falls contributed substantially to low-BMD-attributed outcomes. The authors argue that an aging population makes low BMD a growing health-system priority and call for timely prevention and mitigation efforts.}
}
