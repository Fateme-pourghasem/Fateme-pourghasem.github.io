@article{pourghasem2025scoping,
  abbr={Disabil. Rehabil.},
  title={The use of digital avatars to improve virtual rehabilitation health outcomes amongst adults with health conditions: a scoping review},
  author={Pourghasem, Fateme and Colella, Tracey J. F. and Gopaul, Urvashy and Anderson, Melanie and Ashraf, Ahmed and Khan, Shehroz S.},
  journal={Disability and Rehabilitation},
  pages={2243--2264},
  year={2025},
  publisher={Taylor \& Francis},
  doi={10.1080/09638288.2025.2577878},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:UeHWp8X0CEIC},
  selected={true},
  abstract={Scoping review of digital-avatar interventions in adult virtual rehabilitation. Across 45 studies, avatars were most often used in stroke and amputee rehabilitation and commonly provided real-time feedback; evidence suggested potential benefits for function, adherence, and engagement, but highlighted gaps in AI-driven personalization, privacy/ethics, co-design, standardized measures, and long-term evaluation.}
}

@article{gopaul2024adaptive,
  abbr={Arch. PM\&R},
  title={Development of an adaptive virtual assistant to support virtual rehabilitation of the upper limb after stroke: A co-design approach},
  author={Gopaul, Urvashy and Khan, Shehroz and Abedi, Ali and Pourghasem, Fateme and Bayley, Mark and Colella, Tracey},
  journal={Archives of Physical Medicine and Rehabilitation},
  volume={105},
  number={4},
  pages={e58--e59},
  year={2024},
  doi={10.1016/j.apmr.2024.02.162},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:9yKSN-GCB0IC},
  abstract={Co-designed an on-screen avatar assistant for upper-limb post-stroke virtual rehabilitation through an iterative process with a patient partner and interdisciplinary researchers. The team produced six planar-movement avatar prototypes and identified key design requirements (visible joint/muscle motion, real-time + summative feedback, gamification, progress reporting, personalization, mobile-friendly web delivery, and pre-discharge familiarization) to support engagement and self-management at home.}
}

@misc{abedi2023ava,
  abbr={AI Rehab},
  title={{AVA}: {AI}-driven Virtual Rehabilitation Assistant},
  author={Abedi, Ali and Colella, Tracey J. F. and Bayley, Mark and Gopaul, Urvashy and Mahajan, Abhinav and Reddy, Tarun and Pourghasem, Fateme and Jayagopi, Dinesh Babu and Khan, Shehroz S.},
  year={2023},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:d1gkVwhDpl0C},
  selected={true},
  abstract={Introduces AVA, an AI-driven virtual assistant that helps patients complete prescribed rehabilitation exercises at home by analyzing movement and providing real-time personalized feedback. Delivered as a web app on any camera-enabled computer/phone (no extra hardware), AVA aims to reduce barriers that drive dropout and improve participation and long-term outcomes; a co-design process (including a patient partner) shaped avatar-based training and emphasized real-time guidance.}
}

@mastersthesis{pourghasem2025thesis,
  abbr={MASc},
  title={Feasibility Pilot Testing of an {AI}-based Virtual Assistant among Healthy Adults to Support Virtual Rehabilitation},
  author={Pourghasem, Fateme},
  school={University of Toronto},
  year={2025},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:qjMakFHDy7sC},
  selected={true},
  abstract={Assesses feasibility of an AI-based virtual assistant (AVA) for virtual rehabilitation using cloud computer vision from laptop/phone RGB cameras to track joint motion and guide users via an interactive avatar. In a pilot with healthy adults aged 25--74, AVA showed high usability and positive user experience, while revealing improvement needs (design/attention focus, camera setup) and RGB-tracking limitations (e.g., leg raises), motivating further validation in diverse samples.}
}

@article{azangou2022gbd,
  abbr={Arch. Osteoporos},
  title={Attributable disease burden related to low bone mineral density in {Iran} from 1990 to 2019: results from the {Global Burden of Disease} 2019},
  author={Azangou-Khyavy, Mohammadreza and Saeedi Moghaddam, Sahar and Mohammadi, Esmaeil and Shobeiri, Parnian and Rashidi, Mohammad-Mahdi and Ahmadi, Naser and Shahsavan, Saba and Shirzad Moghaddam, Zeinab and Sohrabi, Hanye and Pourghasem, Fateme and Kalantar, Reyhaneh and Ghaffari, Aydin and Hashemi, Seyedeh Melika and Rezaei, Negar and Larijani, Bagher},
  journal={Archives of Osteoporosis},
  volume={17},
  number={1},
  pages={140},
  year={2022},
  html={https://scholar.google.com/citations?view_op=view_citation&hl=en&user=QS0AxSMAAAAJ&citation_for_view=QS0AxSMAAAAJ:u5HHmVD_uO8C},
  abstract={Quantifies low-bone-mineral-density-attributable burden in Iran (1990--2019) using GBD 2019 exposure and attributable-risk estimates. While age-standardized DALYs/deaths decreased, absolute attributable counts increased; burden was generally higher in males (except Tehran) and motor-vehicle injuries and falls contributed substantially, motivating timely prevention and health-system action in an aging population.}
}
